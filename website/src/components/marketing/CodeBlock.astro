---
import { highlightTS } from "./highlightTS";

interface Props {
  filename?: string;
  code: string;
  compact?: boolean;
}

const { filename = "alchemy.run.ts", code, compact } = Astro.props;
const html = highlightTS(code);
---

<div class:list={["alc-code-block", compact && "alc-code-block--compact"]}>
  <div class="alc-code-block__header">
    <span class="alc-code-block__dot" style="background:var(--alc-danger);"></span>
    <span class="alc-code-block__dot" style="background:var(--alc-warn);"></span>
    <span class="alc-code-block__dot" style="background:var(--alc-accent-bright);"></span>
    <span class="alc-code-block__filename">{filename}</span>
  </div>
  <pre class="alc-code-block__pre" set:html={html} />
</div>
